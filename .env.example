# Copy to `.env` and fill in your key. NEVER commit the real .env.
# The key works for either provider; the model id selects OpenAI vs OpenRouter.

API_KEY=sk-your-key-here
MAIN_MODEL=openai/gpt-5-mini      # OpenAI direct. Or e.g. anthropic/claude-sonnet-4.6 for OpenRouter.

# Optional overrides (see agent/config.py):
# REASONING_EFFORT=low            # minimal|low|medium|high
# TRACKER=local                   # local | clearml
# TARGET_METRIC=val/auprc
# TARGET_DIRECTION=max
# RUN_TIMEOUT_SEC=900
